<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Autobase.dao.DriverDao">

    <resultMap id="driverResultMap" type="com.example.Autobase.model.entities.Driver">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="experienceYears" column="experience_years"/>
        <result property="notes" column="notes"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="getDriverById" resultMap="driverResultMap">
        SELECT * FROM drivers WHERE id = #{id}
    </select>

    <select id="getDriverByUserId" resultMap="driverResultMap">
        SELECT * FROM drivers WHERE user_id = #{userId}
    </select>

    <select id="getAllDrivers" resultMap="driverResultMap">
        SELECT * FROM drivers
    </select>

    <select id="getActiveDrivers" resultMap="driverResultMap">
        SELECT * FROM drivers WHERE status = 'active'
    </select>

    <insert id="addDriver" parameterType="com.example.Autobase.model.entities.Driver" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO drivers (user_id, name, phone, status, experience_years, notes)
        VALUES (#{userId}, #{name}, #{phone}, #{status}, #{experienceYears}, #{notes})
    </insert>

    <update id="updateDriver" parameterType="com.example.Autobase.model.entities.Driver">
        UPDATE drivers
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="name != null">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="status != null">status = #{status},</if>
            <if test="experienceYears != null">experience_years = #{experienceYears},</if>
            <if test="notes != null">notes = #{notes},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateDriverStatus">
        UPDATE drivers SET status = #{status} WHERE id = #{id}
    </update>

    <delete id="deleteDriver">
        DELETE FROM drivers WHERE id = #{id}
    </delete>

</mapper>