<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Autobase.dao.CarDao">

    <resultMap id="carResultMap" type="com.example.Autobase.model.entities.Car">
        <id property="id" column="id"/>
        <result property="model" column="model"/>
        <result property="mark" column="mark"/>
        <result property="color" column="color"/>
        <result property="yearOfRelease" column="year_of_release"/>
        <result property="stateNumber" column="state_number"/>
        <result property="status" column="status"/>
        <result property="mileage" column="mileage"/>
        <result property="notes" column="notes"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="getCarById" resultMap="carResultMap">
        SELECT * FROM cars WHERE id = #{id}
    </select>

    <select id="getCarByStateNumber" resultMap="carResultMap">
        SELECT * FROM cars WHERE state_number = #{stateNumber}
    </select>

    <select id="getAllCar" resultMap="carResultMap">
        SELECT * FROM cars
    </select>

    <select id="getCarByStatus" resultMap="carResultMap">
        SELECT * FROM cars WHERE status = #{status}
    </select>

    <select id="getCarByMark" resultMap="carResultMap">
        SELECT * FROM cars WHERE mark = #{mark}
    </select>

    <select id="getCarByColor" resultMap="carResultMap">
        SELECT * FROM cars WHERE color = #{color}
    </select>

    <select id="getCarByYearOfRelease" resultMap="carResultMap">
        SELECT * FROM cars WHERE year_of_release = #{yearOfRelease}
    </select>

    <insert id="addCar" parameterType="com.example.Autobase.model.entities.Car" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO cars (model, mark, color, year_of_release, state_number, status, mileage, notes)
        VALUES (#{model}, #{mark}, #{color}, #{yearOfRelease}, #{stateNumber}, #{status}, #{mileage}, #{notes})
    </insert>

    <update id="updateCar" parameterType="com.example.Autobase.model.entities.Car">
        UPDATE cars
        <set>
            <if test="model != null">model = #{model},</if>
            <if test="mark != null">mark = #{mark},</if>
            <if test="color != null">color = #{color},</if>
            <if test="yearOfRelease != null">year_of_release = #{yearOfRelease},</if>
            <if test="stateNumber != null">state_number = #{stateNumber},</if>
            <if test="status != null">status = #{status},</if>
            <if test="mileage != null">mileage = #{mileage},</if>
            <if test="notes != null">notes = #{notes},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateCarStatus">
        UPDATE cars SET status = #{status} WHERE id = #{id}
    </update>

    <delete id="deleteCar">
        DELETE FROM cars WHERE id = #{id}
    </delete>

</mapper>