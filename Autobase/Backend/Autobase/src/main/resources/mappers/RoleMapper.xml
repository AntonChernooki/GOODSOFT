<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Autobase.dao.RoleDao">
    <resultMap id="roleResultMap" type="com.example.Autobase.model.entities.Role">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
    </resultMap>

    <select id="getRoleById" resultMap="roleResultMap">
        SELECT * FROM roles WHERE id = #{id}
    </select>

    <select id="getRoleByName" resultMap="roleResultMap">
        SELECT * FROM roles WHERE name = #{name}
    </select>

    <select id="getAllRoles" resultMap="roleResultMap">
        SELECT * FROM roles
    </select>

    <insert id="addRole" parameterType="com.example.Autobase.model.entities.Role" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO roles (name) VALUES (#{name})
    </insert>

    <update id="updateRole" parameterType="com.example.Autobase.model.entities.Role">
        UPDATE roles SET name = #{name} WHERE id = #{id}
    </update>

    <delete id="deleteRole">
        DELETE FROM roles WHERE id = #{id}
    </delete>

</mapper>